rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Public catalog collections (Read: Public, Write: Admin)
    match /rooms/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /upgrades/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews (Read: Public, Create: Authenticated Users, Manage: Admin)
    match /reviews/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // User Profile Documents
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Bookings (Read: Owner or Admin, Create: Authenticated, Update/Delete: Admin or Owner within policy)
    match /bookings/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Wishlists (Owner-scoped)
    match /wishlists/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Notifications (Read: Owner, Write: Serverless Admin SDK)
    match /notifications/{uid} {
      allow read: if isOwner(uid);
      allow write: if isAdmin();
    }

    // Real-Time Guest & Host Chat Threads
    match /chats/{guestUid} {
      allow read, write: if isOwner(guestUid) || isAdmin();
      
      match /messages/{msgId} {
        allow read, write: if isOwner(guestUid) || isAdmin();
      }
    }

    // Newsletter Subscribers
    match /subscribers/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
